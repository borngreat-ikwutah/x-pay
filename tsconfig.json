{
  "compilerOptions": {
    "jsx": "react-jsx",
    "moduleResolution": "Bundler",
    "module": "ESNext",
    "target": "ES2022",
    "skipLibCheck": true,
    "strict": true,
    "strictNullChecks": true,
    "types": ["bun", "vite/client", "node", "react", "react-dom"],
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "baseUrl": ".",
    "paths": {
      "~/*": ["./src/*"],
    },
  },
  "include": ["src", "vite.config.ts"],
  "exclude": ["node_modules", "dist", ".nitro"],
}
